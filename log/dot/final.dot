digraph "def-use" {
  compound=true;
  node [shape=record, fontname="Courier"];
  subgraph "cluster_main" {
    label = "Function: main";
    fontsize = 30; fontname = "Arial Bold";
    style = filled; color = black; fillcolor = white; penwidth = 3.0;
  subgraph "cluster_0x5fca4df8f430" {
    label = "Basic Block: 0x5fca4df8f430";
    style = filled; color = black; penwidth = 2.0; fillcolor = pink;
    "inst_0" [label="{   %1 = alloca i32, align 4 | VALUE: 140721401235260  }"];
    "inst_1" [label="{   store i32 0, ptr %1, align 4 | VALUE: 0  | ADDR: 0x7ffc4122073c  }"];
    "inst_0" -> "inst_1" [style=bold, color=black];
    "inst_1" -> "inst_0" [style=dashed, color=red];
    "inst_2" [label="{   %2 = call i32 @add(i32 noundef 5, i32 noundef 3) | VALUE: 8  }"];
    "inst_1" -> "inst_2" [style=bold, color=black];
    "inst_3" [label="{   %3 = call i32 (ptr, ...) @printf(ptr noundef @.str, i32 noundef %2) | VALUE: 1  }"];
    "inst_2" -> "inst_3" [style=bold, color=black];
    "inst_3" -> "inst_2" [style=dashed, color=red];
    "inst_4" [label="{   ret i32 0 }"];
    "inst_3" -> "inst_4" [style=bold, color=black];
  }
  }
  subgraph "cluster_add" {
    label = "Function: add";
    fontsize = 30; fontname = "Arial Bold";
    style = filled; color = black; fillcolor = white; penwidth = 3.0;
  subgraph "cluster_0x5fca4df92720" {
    label = "Basic Block: 0x5fca4df92720";
    style = filled; color = black; penwidth = 2.0; fillcolor = pink;
    "inst_5" [label="{   %3 = alloca i32, align 4 | VALUE: 140721401235228  }"];
    "inst_6" [label="{   %4 = alloca i32, align 4 | VALUE: 140721401235224  }"];
    "inst_5" -> "inst_6" [style=bold, color=black];
    "inst_7" [label="{   store i32 %0, ptr %3, align 4 | VALUE: 5  | ADDR: 0x7ffc4122071c  }"];
    "inst_6" -> "inst_7" [style=bold, color=black];
    "inst_7" -> "inst_5" [style=dashed, color=red];
    "inst_8" [label="{   store i32 %1, ptr %4, align 4 | VALUE: 3  | ADDR: 0x7ffc41220718  }"];
    "inst_7" -> "inst_8" [style=bold, color=black];
    "inst_8" -> "inst_6" [style=dashed, color=red];
    "inst_9" [label="{   %5 = load i32, ptr %3, align 4 | VALUE: 5  | ADDR: 0x7ffc4122071c  }"];
    "inst_8" -> "inst_9" [style=bold, color=black];
    "inst_9" -> "inst_5" [style=dashed, color=red];
    "inst_10" [label="{   %6 = load i32, ptr %4, align 4 | VALUE: 3  | ADDR: 0x7ffc41220718  }"];
    "inst_9" -> "inst_10" [style=bold, color=black];
    "inst_10" -> "inst_6" [style=dashed, color=red];
    "inst_11" [label="{   %7 = add nsw i32 %5, %6 | VALUE: 8  }"];
    "inst_10" -> "inst_11" [style=bold, color=black];
    "inst_11" -> "inst_9" [style=dashed, color=red];
    "inst_11" -> "inst_10" [style=dashed, color=red];
    "inst_12" [label="{   ret i32 %7 }"];
    "inst_11" -> "inst_12" [style=bold, color=black];
    "inst_12" -> "inst_11" [style=dashed, color=red];
  }
  }
}
